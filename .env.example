# ── Proxy server (npm run server) ────────────────────────────────────────────
# Chave Gemini do tier gratuito, mantida server-side. Sem ela o proxy responde
# /api/status { proxyAvailable: false } e o app cai no modo BYOK.
GEMINI_API_KEY=

# Teto diário global de restaurações do free tier (controla o custo máximo/dia).
# DAILY_RESTORE_CAP=200

# Porta do proxy (Cloud Run injeta automaticamente).
# PORT=3001

# Nível de log do pino: trace|debug|info|warn|error|silent
# LOG_LEVEL=info

# ── Frontend (variáveis de BUILD — nunca coloque a GEMINI_API_KEY aqui em CI) ─
# Analytics PostHog (opcional; sem chave o módulo vira no-op).
# POSTHOG_KEY=phc_...
# POSTHOG_HOST=https://us.i.posthog.com

# E-mail gravado nos metadados EXIF/XMP dos exports.
# USER_EMAIL=voce@exemplo.com

# Base path do build (usado pelo deploy no GitHub Pages).
# DEPLOY_BASE=/RE-Exist/
